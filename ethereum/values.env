# e3vote private PoS network genesis configuration
# Used with ethpandaops/ethereum-genesis-generator

export CHAIN_ID=32382
export PRESET_BASE=mainnet
export NUMBER_OF_VALIDATORS=8
export SLOT_DURATION_IN_SECONDS=${SLOT_DURATION_IN_SECONDS:-12}
export SLOT_DURATION_MS=$(( SLOT_DURATION_IN_SECONDS * 1000 ))

# All forks enabled from genesis (PoS from block 0)
export ALTAIR_FORK_EPOCH=0
export BELLATRIX_FORK_EPOCH=0
export CAPELLA_FORK_EPOCH=0
export DENEB_FORK_EPOCH=0
export ELECTRA_FORK_EPOCH=18446744073709551615
export TERMINAL_TOTAL_DIFFICULTY=0

# Disable future forks
export FULU_FORK_EPOCH=18446744073709551615
export GLOAS_FORK_EPOCH=18446744073709551615

# Genesis timing — set to 0 for auto (deploy.sh will override with current time + delay)
export GENESIS_TIMESTAMP=1776707615
export GENESIS_DELAY=120
export GENESIS_GASLIMIT=30000000

# Validator config
export VALIDATOR_BALANCE=32000000000
export WITHDRAWAL_TYPE=0x01
export WITHDRAWAL_ADDRESS=0xf97e180c050e5Ab072211Ad2C213Eb5AEE4DF134

# Prefunded accounts (8 accounts derived from the mnemonic + extra)
export EL_PREMINE_COUNT=8
export EL_PREMINE_BALANCE=1000000000ETH

# Mnemonic for key derivation (validators + prefunded accounts)
export EL_AND_CL_MNEMONIC="sleep moment list remain like wall lake industry canvas wonder ecology elite duck salad naive syrup frame brass utility club odor country obey pudding"

# Follow distance set to 0 for private testnet (prevents Prysm sync deadlock)
export ETH1_FOLLOW_DISTANCE=0
